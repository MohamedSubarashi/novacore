{
	"apiVersion": 3,
	"name": "novacore/post-grid",
	"title": "Post Grid",
	"category": "novacore",
	"icon": "grid-view",
	"description": "Display posts in a customizable grid layout.",
	"keywords": ["posts", "grid", "blog"],
	"version": "1.0.0",
	"textdomain": "novacore",
	"attributes": {
		"title": {
			"type": "string",
			"default": "Latest Posts"
		},
		"columns": {
			"type": "number",
			"default": 3
		},
		"postsPerPage": {
			"type": "number",
			"default": 6
		},
		"category": {
			"type": "string",
			"default": ""
		},
		"orderBy": {
			"type": "string",
			"default": "date"
		},
		"order": {
			"type": "string",
			"default": "desc"
		},
		"showExcerpt": {
			"type": "boolean",
			"default": true
		},
		"showDate": {
			"type": "boolean",
			"default": true
		},
		"showThumbnail": {
			"type": "boolean",
			"default": true
		},
		"showAuthor": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"align": ["wide", "full"],
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"padding": true,
			"margin": true
		}
	}
}
